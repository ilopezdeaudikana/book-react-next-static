{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "version": "1",
  "applications": {
    "book-react-next-static-memory": {
      "packageName": "memory",
      "routing": [
        {
          "paths": [
            "/memory/:path*"
          ]
        }
      ],
      "development": {
        "local": 5174,
        "fallback": "https://book-react-next-static-memory.vercel.app"
      }
    },
    "github-repos": {
      "packageName": "github-repos",
      "routing": [
        {
          "paths": [
            "/github-repos/:path*"
          ]
        }
      ],
      "development": {
        "local": 3002,
        "fallback": ""
      }
    },
    "ethycunts": {
      "packageName": "ethycunts",
      "routing": [
        {
          "paths": [
            "/ethycunts/:path*"
          ]
        }
      ],
      "development": {
        "local": 5173,
        "fallback": ""
      }
    },
    "book-react-next-static": {
      "packageName": "web",
      "development": {
        "local": 3001,
        "fallback": "https://book-react-next-static.vercel.app"
      }
    }
  }
}