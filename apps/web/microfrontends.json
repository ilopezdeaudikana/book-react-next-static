{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "version": "1",
  "applications": {
    "book-react-next-static-memory": {
      "packageName": "memory",
      "routing": [
        {
          "paths": [
            "/memory", "/memory/:path*"
          ]
        }
      ],
      "development": {
        "local": 5173,
        "fallback": "https://showcase-turborepo-memory.vercel.app"
      }
    },
    "book-react-next-static": {
      "packageName": "web",
      "development": {
        "local": 3001,
        "fallback": "https://book-react-next-static.vercel.app"
      }
    }
  }
}